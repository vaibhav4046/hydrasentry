HYDRA_DB_API_KEY=
HYDRA_DB_TENANT_ID=
HYDRA_DB_SUB_TENANT_ID=hydrasentry-demo
HYDRA_DB_API_BASE_URL=https://api.hydradb.com
HYDRA_DB_API_VERSION=2
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=qwen/qwen3-32b
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=
LOCAL_MODEL_NAME=hydrasentry-risk-judge
APP_MODE=demo
APP_SECRET=
MCP_SHARED_SECRET=
# Signs Memory Integrity Certificates (HMAC-SHA256). Unset = unsigned (honest).
HYDRASENTRY_CERT_SECRET=
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# App store. sqlite for local/offline; Supabase Postgres (session pooler, 5432)
# in production. A Prisma-style ?schema=public param is handled and sslmode is
# forced to require for Postgres. The session pooler (5432) is preferred over the
# transaction pooler (6543) because it supports prepared statements.
# Postgres example (never commit real credentials):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite:///./hydrasentry.db
# Supabase project (server-side keys; never expose the service role key client-side).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
CORS_ORIGINS=http://localhost:3000
